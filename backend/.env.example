# Shared secret required by all API clients. Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# Optional: Get a free API key at https://api.census.gov/data/key_signup.html
# Without a key, requests are rate-limited but still work.
CENSUS_API_KEY=

# Optional: OpenRouteService API key for drive-time isochrone catchments.
# Without a key, a grade-level-calibrated radius fallback is used instead.
# Free tier: 2,000 requests/day. Sign up at https://openrouteservice.org/sign-up/
ORS_API_KEY=

# Frontend URL for CORS (change in production)
FRONTEND_URL=http://localhost:3000

# --- v2: Database & Pipeline Configuration ---

# PostgreSQL + PostGIS connection (required for v2 features)
DATABASE_URL=postgresql+asyncpg://feasibility:feasibility@localhost:5432/feasibility

# Redis URL for Celery task queue
REDIS_URL=redis://localhost:6379/0

# Enable database-backed analysis (set to true after running data pipelines)
USE_DB=false

# SQL query echo (for debugging)
SQL_ECHO=false
