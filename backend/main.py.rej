+def _log_cache_event(endpoint: str, event: str, key: str, **extra):
+    """Structured cache-flow breadcrumbs for runtime observability."""
+    payload = {
+        "endpoint": endpoint,
+        "event": event,
+        "key": key,
+    }
+    payload.update(extra)
+    logger.info("cache_diagnostic %s", json.dumps(payload, sort_keys=True))
+
