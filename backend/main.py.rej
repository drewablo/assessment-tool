+def _trace_log(event: str, **fields):
+    """TEMP_DIAGNOSTIC: request-scoped trace breadcrumbs for analysis flows."""
+    payload = {
+        "event": event,
+        "request_id": _request_id_ctx.get(),
+        "pid": os.getpid(),
+    }
+    payload.update(fields)
+    logger.info("runtime_trace %s", json.dumps(payload, sort_keys=True))
+
+
+def _request_fingerprint(request: AnalysisRequest) -> str:
+    payload = json.dumps(
+        {
+            "address": " ".join(request.address.strip().lower().split()),
+            "ministry_type": request.ministry_type,
+            "drive_minutes": request.drive_minutes,
+            "grade_level": request.grade_level,
+            "gender": request.gender,
+            "weighting_profile": request.weighting_profile,
+            "market_context": request.market_context,
+            "mission_mode": request.mission_mode,
+            "care_level": request.care_level,
+            "min_mds_overall_rating": request.min_mds_overall_rating,
+        },
+        sort_keys=True,
+    )
+    return hashlib.sha256(payload.encode()).hexdigest()[:16]
+
+
 def _now_utc() -> datetime:
     return datetime.now(timezone.utc)
 
