# URL of the FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Shared API key — must match INTERNAL_API_KEY in the backend .env
NEXT_PUBLIC_API_KEY=

# NextAuth — generate NEXTAUTH_SECRET with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Alpha team credentials: comma-separated username:password pairs
# Example: AUTH_USERS=alice:hunter2,bob:correct-horse
AUTH_USERS=
