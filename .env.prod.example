# ============================================================
# Production environment — copy to .env.prod and fill in values.
# NEVER commit .env.prod to version control.
# ============================================================

# ---- Deployment ----
# The public URL where this app will be served (no trailing slash).
# If behind a domain: https://yourdomain.com
# If using only an IP: http://YOUR_SERVER_IP
FRONTEND_URL=https://yourdomain.com

# ---- Database ----
# PostgreSQL credentials (change from defaults before deploying)
DB_USER=feasibility
DB_PASSWORD=CHANGE_ME_strong_password_here

# ---- Auth ----
# Shared secret between frontend and backend.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_generate_with_openssl

# NextAuth session signing secret.
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl

# Alpha team credentials — comma-separated username:password pairs.
# Example: AUTH_USERS=alice:hunter2,bob:correct-horse-battery
AUTH_USERS=CHANGE_ME

# ---- External APIs ----
# Required for school audit PDF extraction (Claude-powered)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: higher Census rate limits (free at api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# Optional: drive-time isochrone catchments (free tier at openrouteservice.org)
ORS_API_KEY=

# ---- Feature Flags ----
# Set to true once DB pipelines have been run and precomputed data is available
USE_DB=true
